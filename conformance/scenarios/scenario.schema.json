{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terminal-todo.dev/conformance/scenario.schema.json",
  "title": "terminal-todo real-agent conformance scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "summary",
    "initial_time",
    "actors",
    "project",
    "turns",
    "assertions"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "initial_time": {"type": "string", "format": "date-time"},
    "skill_policy": {
      "enum": ["project_integration", "not_preloaded"]
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 600,
      "default": 120
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "name", "capabilities"],
        "properties": {
          "ref": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "name": {"type": "string", "minLength": 1},
          "capabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "max_load": {"type": "integer", "minimum": 0}
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initialized", "tasks"],
      "properties": {
        "initialized": {"type": "boolean"},
        "tasks": {
          "type": "array",
          "items": {"$ref": "#/$defs/task"}
        }
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/turn"}
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/assertion"}
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "title", "status", "capabilities", "depends_on"],
      "properties": {
        "ref": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "title": {"type": "string", "minLength": 1},
        "status": {
          "enum": ["pending", "in_progress", "completed", "blocked"]
        },
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^task:[a-z][a-z0-9_]*$"}
        },
        "owner": {"type": "string", "pattern": "^actor:[a-z][a-z0-9_]*$"},
        "lease_expires": {"type": "string", "format": "date-time"},
        "metadata": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "by", "action"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "by": {
          "type": "string",
          "pattern": "^(harness|actor:[a-z][a-z0-9_]*)$"
        },
        "action": {
          "enum": [
            "prompt",
            "advance_clock",
            "concurrent_turns",
            "checkpoint",
            "resume"
          ]
        },
        "prompt": {"type": "string", "minLength": 1},
        "seconds": {"type": "integer", "minimum": 1},
        "actors": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^actor:[a-z][a-z0-9_]*$"}
        },
        "instruction": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"const": "prompt"}}},
          "then": {"required": ["prompt"]}
        },
        {
          "if": {"properties": {"action": {"const": "advance_clock"}}},
          "then": {"required": ["seconds"]}
        },
        {
          "if": {"properties": {"action": {"const": "concurrent_turns"}}},
          "then": {"required": ["actors", "prompt"]}
        },
        {
          "if": {
            "properties": {
              "action": {"enum": ["checkpoint", "resume"]}
            }
          },
          "then": {"required": ["instruction"]}
        }
      ]
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "description", "criteria", "expect"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "kind": {
          "enum": [
            "operation_trace",
            "task_state",
            "event_log",
            "domain_error",
            "assistant_output"
          ]
        },
        "description": {"type": "string", "minLength": 1},
        "criteria": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        },
        "hard_gate": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "expect": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      }
    }
  }
}
