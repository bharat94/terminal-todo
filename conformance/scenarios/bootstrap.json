{
  "schema_version": "1",
  "id": "bootstrap",
  "title": "Start with one bounded brief",
  "summary": "The worker resumes through bootstrap instead of dumping the complete graph and event history.",
  "initial_time": "2026-01-01T12:00:00Z",
  "skill_policy": "project_integration",
